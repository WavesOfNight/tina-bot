# This project stores the Discord bot token in the database (configured from
# the web panel's Settings page after your first login), not in an env file.
# The variables below are only generic app secrets, never Discord credentials.

# Shared SQLite database used by both the bot and the web dashboard.
# Must be an ABSOLUTE path (identical) in packages/database/.env, apps/bot/.env
# and apps/web/.env.local so all three processes read/write the same file.
DATABASE_URL="file:C:/absolute/path/to/Tina BOT/packages/database/prisma/dev.db"

# Symmetric key used to encrypt/decrypt the bot token at rest in the database.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be IDENTICAL in apps/bot/.env and apps/web/.env.local.
TOKEN_ENCRYPTION_KEY=

# Optional (apps/bot/.env only): deploy slash commands to a single guild instantly
# for development. Leave empty for a global deploy (propagates within ~1h).
DISCORD_DEV_GUILD_ID=

# Web dashboard only (apps/web/.env.local): secret used by NextAuth/Auth.js to
# sign admin session cookies. Generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
