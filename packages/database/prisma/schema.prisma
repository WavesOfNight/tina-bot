generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Reminder {
  id        Int      @id @default(autoincrement())
  guildId   String
  channelId String
  userId    String
  message   String
  remindAt  DateTime
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([remindAt, sent])
}

model BotConfig {
  id                          Int      @id @default(1)
  clientId                    String
  tokenEncrypted              String
  clientSecretEncrypted       String?
  twitchClientId               String?
  twitchClientSecretEncrypted String?
  updatedAt                   DateTime @updatedAt
}

model TwitchBotConfig {
  id                    Int       @id @default(1)
  username              String?
  channelName           String?
  clientId              String?
  clientSecretEncrypted String?
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  tokenExpiresAt        DateTime?
  linkedGuildId         String?
  autoModLevel          String    @default("OFF")
  prefix                String    @default("!")
  enabled               Boolean   @default(false)

  filterLinksEnabled      Boolean @default(false)
  linkWhitelist           String  @default("")
  filterCapsEnabled       Boolean @default(false)
  filterEmotesEnabled     Boolean @default(false)
  maxEmotes               Int     @default(5)
  filterSymbolsEnabled    Boolean @default(false)
  filterRepetitionEnabled Boolean @default(false)
  filterSharedChatEnabled Boolean @default(false)

  updatedAt             DateTime  @updatedAt
}

model TwitchCommand {
  id              Int       @id @default(autoincrement())
  name            String    @unique
  response        String
  cooldownSeconds Int       @default(5)
  uses            Int       @default(0)
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())
}

model TwitchModerationCase {
  id        Int      @id @default(autoincrement())
  username  String
  type      String
  reason    String?
  createdAt DateTime @default(now())

  @@index([username])
}

model TwitchTimer {
  id              Int       @id @default(autoincrement())
  name            String
  message         String
  intervalMinutes Int       @default(10)
  minMessages     Int       @default(0)
  enabled         Boolean   @default(true)
  lastSentAt      DateTime?
  createdAt       DateTime  @default(now())
}

model TwitchGiveaway {
  id             Int                   @id @default(autoincrement())
  keyword        String
  prize          String
  status         String                @default("ACTIVE")
  winnerUsername String?
  createdAt      DateTime              @default(now())
  endedAt        DateTime?
  entries        TwitchGiveawayEntry[]
}

model TwitchGiveawayEntry {
  id         Int            @id @default(autoincrement())
  giveaway   TwitchGiveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  giveawayId Int
  username   String
  createdAt  DateTime       @default(now())

  @@unique([giveawayId, username])
}

model TwitchDailyStat {
  id       Int    @id @default(autoincrement())
  date     String @unique
  messages Int    @default(0)
  commands Int    @default(0)
  timeouts Int    @default(0)
}

model TwitchChatterStat {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  messages   Int      @default(0)
  lastSeenAt DateTime @default(now())
}

model Guild {
  id                  String   @id
  name                String?
  prefix              String   @default("!")
  modLogChannelId     String?
  autoModLevel        String   @default("OFF")
  filterInvites       Boolean  @default(false)
  filterLinks         Boolean  @default(false)
  filterCaps          Boolean  @default(false)
  filterSpam          Boolean  @default(false)
  warnMuteThreshold   Int?
  warnKickThreshold   Int?
  warnBanThreshold    Int?
  statsChannelId      String?
  radioChannelId      String?
  radioEnabled        Boolean  @default(false)
  permanentInviteCode      String?
  permanentInviteChannelId String?
  createdAt           DateTime @default(now())

  welcomeConfig      WelcomeConfig?
  members            Member[]
  levelRewards       LevelReward[]
  moderationCases    ModerationCase[]
  customCommands     CustomCommand[]
  autoResponses      AutoResponse[]
  giveaways          Giveaway[]
  reactionRoleMsgs   ReactionRoleMessage[]
  gameStats          GameStat[]
  slashCommandToggle SlashCommandToggle[]
  collabStory        CollabStory?
  socialAlerts       SocialAlert[]
}

model SocialAlert {
  id               Int      @id @default(autoincrement())
  guild            Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId          String
  platform         String
  channelRef       String
  discordChannelId String
  message          String   @default("{channel} vient de publier du nouveau contenu ! {url}")
  lastSeenId       String?
  createdAt        DateTime @default(now())

  @@unique([guildId, platform, channelRef])
}

model CollabStory {
  id         Int      @id @default(autoincrement())
  guild      Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId    String   @unique
  content    String   @default("")
  lastUserId String?
  updatedAt  DateTime @updatedAt
}

model BotActivity {
  id              Int      @id @default(autoincrement())
  type            String   @default("WATCHING")
  text            String
  durationSeconds Int      @default(30)
  order           Int      @default(0)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model WelcomeConfig {
  id                  Int      @id @default(autoincrement())
  guild               Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId             String   @unique
  channelId           String?
  message             String   @default("{user.mention} a rejoint le serveur {server.name} !")
  imageEnabled        Boolean  @default(true)
  imageText           String   @default("Bienvenue {user} !")
  imageBackgroundUrl  String?
  dmEnabled           Boolean  @default(false)
  dmMessage           String   @default("Bienvenue sur {server.name}, {user.name} !")
  reactionRoleEnabled Boolean  @default(false)
  reactionRoleId      String?
  autoRoleEnabled     Boolean  @default(false)
  autoRoleId          String?
  updatedAt           DateTime @updatedAt
}

model AutoResponse {
  id        Int      @id @default(autoincrement())
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId   String
  trigger   String
  response  String
  matchType String   @default("CONTAINS")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([guildId])
}

model Member {
  id        Int      @id @default(autoincrement())
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId   String
  userId    String
  xp        Int      @default(0)
  level     Int      @default(0)
  messages  Int      @default(0)
  lastXpAt  DateTime?

  @@unique([guildId, userId])
  @@index([guildId, xp])
}

model LevelReward {
  id      Int    @id @default(autoincrement())
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId String
  level   Int
  roleId  String

  @@unique([guildId, level])
}

model ModerationCase {
  id          Int       @id @default(autoincrement())
  guild       Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId     String
  userId      String
  moderatorId String
  type        String
  reason      String?
  expiresAt   DateTime?
  resolved    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([guildId, userId])
}

model CustomCommand {
  id        Int      @id @default(autoincrement())
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId   String
  name      String
  response  String
  createdAt DateTime @default(now())
  actions   CustomCommandAction[]

  @@unique([guildId, name])
}

model CustomCommandAction {
  id              Int                    @id @default(autoincrement())
  customCommand   CustomCommand          @relation(fields: [customCommandId], references: [id], onDelete: Cascade)
  customCommandId Int
  parent          CustomCommandAction?   @relation("ActionChildren", fields: [parentId], references: [id], onDelete: Cascade)
  parentId        Int?
  children        CustomCommandAction[]  @relation("ActionChildren")
  branch          String?
  order           Int
  type            String
  config          String
  createdAt       DateTime               @default(now())

  @@index([customCommandId])
  @@index([parentId])
}

model CustomCommandVariable {
  id        Int      @id @default(autoincrement())
  guildId   String
  name      String
  value     String   @default("")
  updatedAt DateTime @updatedAt

  @@unique([guildId, name])
}

model Giveaway {
  id           Int             @id @default(autoincrement())
  guild        Guild           @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId      String
  channelId    String
  messageId    String?
  prize        String
  winnerCount  Int             @default(1)
  hostId       String
  endsAt       DateTime
  ended        Boolean         @default(false)
  createdAt    DateTime        @default(now())
  entries      GiveawayEntry[]
}

model GiveawayEntry {
  id         Int      @id @default(autoincrement())
  giveaway   Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  giveawayId Int
  userId     String
  createdAt  DateTime @default(now())

  @@unique([giveawayId, userId])
}

model ReactionRoleMessage {
  id        Int                   @id @default(autoincrement())
  guild     Guild                 @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId   String
  channelId String
  messageId String?
  title     String                @default("Roles")
  dirty     Boolean               @default(true)
  buttons   ReactionRoleButton[]
  createdAt DateTime              @default(now())
}

model ReactionRoleButton {
  id        Int                  @id @default(autoincrement())
  message   ReactionRoleMessage  @relation(fields: [messageId_fk], references: [id], onDelete: Cascade)
  messageId_fk Int
  roleId    String
  emoji     String?
  label     String

  @@unique([messageId_fk, roleId])
}

model GameStat {
  id      Int    @id @default(autoincrement())
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId String
  userId  String
  game    String
  wins    Int    @default(0)
  losses  Int    @default(0)
  draws   Int    @default(0)
  plays   Int    @default(0)

  @@unique([guildId, userId, game])
}

model SlashCommandToggle {
  id      Int     @id @default(autoincrement())
  guild   Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId String
  name    String
  enabled Boolean @default(true)

  @@unique([guildId, name])
}
